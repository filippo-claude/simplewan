config globals 'globals'
	option enabled '1'
	# Interface preferred while healthy, and the one to fail over to.
	# Set their route metrics in the normal Network config so the primary
	# is lower (e.g. wan=10, wan2=20); simplewan reads those.
	option primary 'wan'
	option backup 'wan2'
	# Single IPv4 target, pinged out of each WAN.
	option ping_target '1.1.1.1'
	# Seconds the primary must stay healthy before switching back to it after
	# a failover. (Detection cadence and thresholds are fixed in the daemon:
	# ~10s to catch a dead link, ~60s window for high packet loss.)
	option recovery_time '300'
	option flush_conntrack '1'

# Optional email via Postmark. The token lives here; this file is installed
# mode 0600. Leave enabled '0' to disable.
config notify 'notify'
	option enabled '0'
	option postmark_token ''
	option mail_from 'router@example.com'
	option mail_to 'you@example.com'
	option subject_prefix '[simplewan]'
