#!/bin/sh /etc/rc.common

USE_PROCD=1
START=95
STOP=10

PROG=/usr/bin/simplewand

start_service() {
	# Honor the config switch here rather than letting the daemon start and
	# exit: with procd "respawn" set, an immediate exit would otherwise loop.
	config_load simplewan
	local enabled
	config_get_bool enabled globals enabled 1
	[ "$enabled" = 1 ] || return 0

	procd_open_instance
	procd_set_param command "$PROG"
	procd_set_param respawn
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	# Config reload restarts the daemon; routes are left in place across the
	# restart, so this never interrupts connectivity.
	restart
}

service_triggers() {
	procd_add_reload_trigger "simplewan"
}
